<!--Layout Horizontal-->
<form action="">

<div class="container pb-5">
    <div class="row  mt-3 mb-4">
        <div class="col">
            <div class="card">
                <div class="card-header text-center">
                    <h4 class="card-title">Laporan PNP</h4>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="mt-3 d-grid gap-2 d-md-flex justify-content-md-start">
            <button class="btn btn-secondary" id="btn-ambil-data" type="button">Ambil Data</button>
            <button class="btn btn-primary" type="button">Screenshoot</button>
        </div>
    </div>

    <%# format baru %>
    <div class="row">
        <%# kolom kiri %>
            <div class="col-12 col-lg-4 me-3">
                <p class="card-title mt-3 mb-3"><%= hariIni  %>, <span class="fw-bold">Pukul 06:00</span> </p>
                <%# card cuaca %>
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title text-primary">
                                <span class="me-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                        fill="currentColor" class="bi bi-cloud-lightning-fill" viewBox="0 0 16 16">
                                        <path
                                            d="M7.053 11.276A.5.5 0 0 1 7.5 11h1a.5.5 0 0 1 .474.658l-.28.842H9.5a.5.5 0 0 1 .39.812l-2 2.5a.5.5 0 0 1-.875-.433L7.36 14H6.5a.5.5 0 0 1-.447-.724zm6.352-7.249a5.001 5.001 0 0 0-9.499-1.004A3.5 3.5 0 1 0 3.5 10H13a3 3 0 0 0 .405-5.973" />
                                    </svg>
                                </span>
                                Kondisi Cuaca
                            </h5>
                        </div>

                        <div class="card-body">
                            <input type="radio" class="btn-check" name="kondisi-cuaca" id="radioBerawan"
                                autocomplete="off">
                            <label class="btn  btn-sm btn-outline-primary" for="radioBerawan">Berawan</label>

                            <input type="radio" class="btn-check" name="kondisi-cuaca" id="radioCerah"
                                autocomplete="off" checked>
                            <label class="btn  btn-sm btn-outline-primary" for="radioCerah">Cerah</label>

                            <input type="radio" class="btn-check" name="kondisi-cuaca" id="radioGerimis"
                                autocomplete="off">
                            <label class="btn  btn-sm btn-outline-primary" for="radioGerimis">Gerimis</label>

                            <input type="radio" class="btn-check" name="kondisi-cuaca" id="radioHujan"
                                autocomplete="off">
                            <label class="btn  btn-sm btn-outline-primary" for="radioHujan">Hujan</label>

                            <input type="radio" class="btn-check" name="kondisi-cuaca" id="radioMendung"
                                autocomplete="off">
                            <label class="btn  btn-sm btn-outline-primary" for="radioMendung">Mendung</label>

                        </div>
                    </div>
                    <%# card beban %>
                        <div class="card mt-3">

                            <div class="card-header">
                                <h5 class="card-title text-primary">
                                    <span class="me-2"><svg xmlns="http://www.w3.org/2000/svg" width="22"
                                            height="22 " fill="currentColor" class="bi bi-plug-fill"
                                            viewBox="0 0 16 16">
                                            <path
                                                d="M6 0a.5.5 0 0 1 .5.5V3h3V.5a.5.5 0 0 1 1 0V3h1a.5.5 0 0 1 .5.5v3A3.5 3.5 0 0 1 8.5 10c-.002.434-.01.845-.04 1.22-.041.514-.126 1.003-.317 1.424a2.08 2.08 0 0 1-.97 1.028C6.725 13.9 6.169 14 5.5 14c-.998 0-1.61.33-1.974.718A1.92 1.92 0 0 0 3 16H2c0-.616.232-1.367.797-1.968C3.374 13.42 4.261 13 5.5 13c.581 0 .962-.088 1.218-.219.241-.123.4-.3.514-.55.121-.266.193-.621.23-1.09.027-.34.035-.718.037-1.141A3.5 3.5 0 0 1 4 6.5v-3a.5.5 0 0 1 .5-.5h1V.5A.5.5 0 0 1 6 0" />
                                        </svg></span>
                                    Beban
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="input-group mb-3">
                                    <span class="input-group-text">GT21</span>
                                    <input type="text" class="form-control"
                                        aria-label="Amount (to the nearest dollar)">
                                    <span class="input-group-text">MW</span>
                                </div>
                                <div class="input-group mb-3">
                                    <span class="input-group-text">GT22</span>
                                    <input type="text" class="form-control"
                                        aria-label="Amount (to the nearest dollar)">
                                    <span class="input-group-text">MW</span>
                                </div>
                                <div class="input-group mb-3">
                                    <span class="input-group-text">ST28</span>
                                    <input type="text" class="form-control"
                                        aria-label="Amount (to the nearest dollar)">
                                    <span class="input-group-text">MW</span>
                                </div>
                                <div class="input-group">
                                    <span class="input-group-text">Total Beban</span>
                                    <input type="text" class="form-control"
                                        aria-label="Amount (to the nearest dollar)">
                                    <span class="input-group-text">MW</span>
                                </div>

                            </div>
                        </div>
                        <%# card flow gas %>
                            <div class="card mt-3">
                                <div class="card-header">
                                    <h5 class="card-title text-primary">
                                        <span class="me-2"><svg xmlns="http://www.w3.org/2000/svg" width="16"
                                                height="16" fill="currentColor" class="bi bi-safe2-fill"
                                                viewBox="0 0 16 16">
                                                <path
                                                    d="M6.563 8H5.035a3.5 3.5 0 0 1 .662-1.596l1.08 1.08q-.142.24-.214.516m.921-1.223-1.08-1.08A3.5 3.5 0 0 1 8 5.035v1.528q-.277.072-.516.214M9 6.563V5.035a3.5 3.5 0 0 1 1.596.662l-1.08 1.08A2 2 0 0 0 9 6.563m1.223.921 1.08-1.08c.343.458.577 1.003.662 1.596h-1.528a2 2 0 0 0-.214-.516M10.437 9h1.528a3.5 3.5 0 0 1-.662 1.596l-1.08-1.08q.142-.24.214-.516m-.921 1.223 1.08 1.08A3.5 3.5 0 0 1 9 11.965v-1.528q.277-.072.516-.214M8 10.437v1.528a3.5 3.5 0 0 1-1.596-.662l1.08-1.08q.24.142.516.214m-1.223-.921-1.08 1.08A3.5 3.5 0 0 1 5.035 9h1.528q.072.277.214.516M7.5 8.5a1 1 0 1 1 2 0 1 1 0 0 1-2 0" />
                                                <path
                                                    d="M2.5 1A1.5 1.5 0 0 0 1 2.5V3H.5a.5.5 0 0 0 0 1H1v4H.5a.5.5 0 0 0 0 1H1v4H.5a.5.5 0 0 0 0 1H1v.5A1.5 1.5 0 0 0 2.5 16h12a1.5 1.5 0 0 0 1.5-1.5v-12A1.5 1.5 0 0 0 14.5 1zm6 3a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9" />
                                            </svg></span>
                                        Flow Gas
                                    </h5>
                                </div>

                                <div class="card-body">
                                    <div class="input-group mb-3">
                                        <span class="input-group-text" style="width: 7.5rem;">GT21 + Blok 1</span>
                                        <input type="text" class="form-control"
                                            aria-label="Amount (to the nearest dollar)">
                                        <span class="input-group-text">MMSCFD</span>
                                    </div>
                                    <div class="input-group mb-3">
                                        <span class="input-group-text" style="width: 7.5rem;">GT22</span>
                                        <input type="text" class="form-control"
                                            aria-label="Amount (to the nearest dollar)">
                                        <span class="input-group-text">MMSCFD</span>
                                    </div>
                                </div>
                            </div>
            </div>
            <%# kolom tengah %>
            <div class="col-12 col-lg-4 me-3">
            <p class="card-title mt-3 mb-3"><%= hariIni  %>, <span class="fw-bold">Pukul 00:00</span>
                <%# card energi %>
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title text-primary">
                                <span class="me-2"><svg xmlns="http://www.w3.org/2000/svg" width="16"
                                        height="16" fill="currentColor" class="bi bi-fire" viewBox="0 0 16 16">
                                        <path
                                            d="M8 16c3.314 0 6-2 6-5.5 0-1.5-.5-4-2.5-6 .25 1.5-1.25 2-1.25 2C11 4 9 .5 6 0c.357 2 .5 4-2 6-1.25 1-2 2.729-2 4.5C2 14 4.686 16 8 16m0-1c-1.657 0-3-1-3-2.75 0-.75.25-2 1.25-3C6.125 10 7 10.5 7 10.5c-.375-1.25.5-3.25 2-3.5-.179 1-.25 2 1 3 .625.5 1 1.364 1 2.25C11 14 9.657 15 8 15" />
                                    </svg></span>

                                Energi
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="input-group mb-3">
                                <span class="input-group-text" style="width: 7.5rem;">GT21 + Blok 1</span>
                                <input type="text" class="form-control"
                                    aria-label="Amount (to the nearest dollar)" value="<%= energiB1 %>">
                                <span class="input-group-text">MMBtu</span>
                            </div>
                            <div class="input-group">
                                <span class="input-group-text" style="width: 7.5rem;">GT22</span>
                                <input type="text" class="form-control"
                                    aria-label="Amount (to the nearest dollar)" value="<%= energiB2 %>">
                                <span class="input-group-text">MMbtu</span>
                            </div>
                        </div>
                    </div>
                    <%# card produksi blok 1 %>
                        <div class="card mt-3">
                            <div class="card-header">
                                <h5 class="card-title text-primary">
                                    <span class="me-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                            fill="currentColor" class="bi bi-layers-half" viewBox="0 0 16 16">
                                            <path
                                                d="M8.235 1.559a.5.5 0 0 0-.47 0l-7.5 4a.5.5 0 0 0 0 .882L3.188 8 .264 9.559a.5.5 0 0 0 0 .882l7.5 4a.5.5 0 0 0 .47 0l7.5-4a.5.5 0 0 0 0-.882L12.813 8l2.922-1.559a.5.5 0 0 0 0-.882zM8 9.433 1.562 6 8 2.567 14.438 6z" />
                                        </svg>
                                    </span>

                                    Produksi Blok 1
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="input-group mb-3">
                                    <span class="input-group-text">GT11</span>
                                    <input type="text" class="form-control">
                                    <span class="input-group-text">KWh</span>
                                </div>
                                <div class="input-group mb-3">
                                    <span class="input-group-text">GT12</span>
                                    <input type="text" class="form-control">
                                    <span class="input-group-text">KWh</span>
                                </div>
                                <div class="input-group">
                                    <span class="input-group-text">ST18</span>
                                    <input type="text" class="form-control">
                                    <span class="input-group-text">KWh</span>
                                </div>
                            </div>
                        </div>
                        <%# card produksi blok 2 %>
                            <div class="card mt-3">
                                <div class="card-header">
                                    <h5 class="card-title text-primary">
                                        <span class="me-2">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                fill="currentColor" class="bi bi-layers-fill"
                                                viewBox="0 0 16 16">
                                                <path
                                                    d="M7.765 1.559a.5.5 0 0 1 .47 0l7.5 4a.5.5 0 0 1 0 .882l-7.5 4a.5.5 0 0 1-.47 0l-7.5-4a.5.5 0 0 1 0-.882z" />
                                                <path
                                                    d="m2.125 8.567-1.86.992a.5.5 0 0 0 0 .882l7.5 4a.5.5 0 0 0 .47 0l7.5-4a.5.5 0 0 0 0-.882l-1.86-.992-5.17 2.756a1.5 1.5 0 0 1-1.41 0z" />
                                            </svg>
                                        </span>

                                        Produksi Blok 2
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="input-group mb-3">
                                        <span class="input-group-text">GT21</span>
                                        <input type="text" class="form-control" value="<%= prod21 %>">
                                        <span class="input-group-text">KWh</span>
                                    </div>
                                    <div class="input-group mb-3">
                                        <span class="input-group-text">GT22</span>
                                        <input type="text" class="form-control" value="<%= prod22 %>">
                                        <span class="input-group-text">KWh</span>
                                    </div>
                                    <div class="input-group mb-3">
                                        <span class="input-group-text">ST28</span>
                                        <input type="text" class="form-control" value="<%= prod28 %>">
                                        <span class="input-group-text">KWh</span>
                                    </div>
                                </div>
                            </div>
            </div>
            <%#kolom kanan %>
            <div class="col-12 col-lg-3 mt-5">
                <div class="card" style="width: 22rem; max-height: 22rem;">
                    <div class="card-header">
                        <h3>PRODUKSI</h3>
                    </div>
                    <div class="card-body">
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <h5>Blok 1 : <span id="total-kwh-b1">0</span> KWh</h5>
                            </li>
                            <li class="list-group-item">
                                <h5>Blok 2 : <span id="total-kwh-b2">0</span> KWh</h5>
                            </li>
                        </ul>
                    </div>
                    <div class="card-footer">
                        <h4>Total <span class="text-primary" id="total-kwh">0</span> KWh</h4>
                    </div>
                </div>
            </div>
    </div>

    <%# ---------------------------------------------------------------------------------------------------------------- %>

    <!--screenshoot display result-->
</div>
</form>