  const areaLaporan = document.querySelector('textarea');

  function getFormData() {
    const formData = new FormData(formKoordinasi);
    const keys = ['jam', 'beban21', 'beban22', 'beban28', 'totalBeban', 'vacuum', 'ps', 'totalProduksi', 'agc21', 'agc22', 'pNG21', 'pNG22', 'fNG21', 'fNG22', 'psi', 'areaLaporan'];
    
    for (let index = 0; index < formKoordinasi.length; index++) {
      formData[keys[index]] = formKoordinasi[index].value;
      console.log(keys[index]);
      console.log(formKoordinasi[index].value);
      
    }
    return formData
  }
  function formHandler(evt) {
    evt.preventDefault();
    const option = {
      method: formKoordinasi.method,
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify(getFormData())
    }
    whatsapp(formKoordinasi.action, option);
    modalHandler('Copy Berhasil', 'Silahkan paste laporan di group whatsapp <strong>Koordinasi PLTGU Sengkang!</strong>', 'OK')
  }

  const btnGas = document.getElementById('btn-gas');
  btnGas.addEventListener('click', gasHandler1)
  async function gasHandler(params) {
    const url = '/koordinasi/gas'
    const option = {
      method : 'get'
    }
    try {
      const response = await fetch(url, option);
      const data = await response.json();
      console.log(data);
    } catch (err) {
      console.error(err);
      
    }
  }

  async function gasHandler1() {
      const url = '/koordinasi/gas'
      const option = {
        method: formKoordinasi.method,
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(getFormData())
      }
      try {
        const response = await fetch(url, option)
        const data = await response.json()
        areaLaporan.innerHTML = data;
        areaLaporan.select();
        document.execCommand('copy');
        modalHandler('Copy Berhasil', 'Silahkan paste laporan di group whatsapp <strong>Koordinasi Gas!</strong>', 'OK')
      } catch (err) {
        console.error(err);
      }
  }
  async function whatsapp(url, option) {
    try {
      const response = await fetch(url, option);
      const data = await response.json()
      areaLaporan.innerHTML = data;
      areaLaporan.select();
      document.execCommand('copy');
    } catch (error) {
      console.error(error)
    }
  }
  agc21.addEventListener('change', (evt) => {
    if (evt.target.checked) {
      lbl21.innerHTML = 'AGC GT21 ON'
      evt.target.value = 'on'
    } else {
      lbl21.innerHTML = 'AGC GT21 OFF'
      evt.target.value = 'off'
    }
  })
  agc22.addEventListener('change', (evt) => {
    if (evt.target.checked) {
      lbl22.innerHTML = 'AGC GT22 ON'
      evt.target.value = 'on'
    } else {
      lbl22.innerHTML = 'AGC GT22 OFF'
      evt.target.value = 'off'
    }
  })
  function isNumber(params) {
    return +params
  }
  function modalHandler(title, body, actionSatu, actionDua) {
    const modalElement = document.getElementById('exampleModal')
    const modal = new bootstrap.Modal(modalElement);
    const modalTitle = document.querySelector('.modal-title')
    const modalBody = document.querySelector('.modal-body')
    const btnModalAction1 = document.getElementById('btn-modal-action-1')
    const btnModalAction2 = document.getElementById('btn-modal-action-2')

    modalTitle.innerHTML = title
    modalBody.innerHTML = body
    btnModalAction1.innerHTML = actionSatu
    btnModalAction2.innerHTML = actionDua
    if (btnModalAction2.innerHTML == 'undefined') {
      btnModalAction2.style.display = 'none'
      btnModalAction1.classList.add('btn-primary')
      btnModalAction1.classList.remove('btn-secondary')
    }
    if (btnModalAction1.innerHTML == 'Action1') {
      btnModalAction1.style.display = 'none'
    }
    modal.show()
  }
