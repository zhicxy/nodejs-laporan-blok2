<form action="/koordinasi/wa" method="post">
<div class="row me-3 mt-3">
    <div class="col-12 col-lg-6 col-xl-4">

        <!--card jam-->
        <div class="card">

            <div class="card-header">
                <h4 class="card-title">Laporan Whatsapp</h4>
            </div>
            <div class="card-body">
                <p class="card-title">
                    <%= hariIni %>
                </p>
                <div class="input-group mb-3">
                    <span class="input-group-text">Pukul</span>
                    <select class="form-select" id="select-jam" aria-label="Default select example">
                        <option selected disabled value="">----</option>
                        <option value="06:00">06:00</option>
                        <option value="16:00">16:00</option>
                        <option value="17:00">17:00</option>
                        <option value="18:00">18:00</option>
                    </select>
                    <span class="input-group-text">WITA</span>
                </div>
            </div>
        </div>

        <!--Card Beban-->
        <div class="card mt-3">

            <div class="card-header">
                <h5 class="card-title text-primary">
                    <span class="me-2"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22 "
                            fill="currentColor" class="bi bi-plug-fill" viewBox="0 0 16 16">
                            <path
                                d="M6 0a.5.5 0 0 1 .5.5V3h3V.5a.5.5 0 0 1 1 0V3h1a.5.5 0 0 1 .5.5v3A3.5 3.5 0 0 1 8.5 10c-.002.434-.01.845-.04 1.22-.041.514-.126 1.003-.317 1.424a2.08 2.08 0 0 1-.97 1.028C6.725 13.9 6.169 14 5.5 14c-.998 0-1.61.33-1.974.718A1.92 1.92 0 0 0 3 16H2c0-.616.232-1.367.797-1.968C3.374 13.42 4.261 13 5.5 13c.581 0 .962-.088 1.218-.219.241-.123.4-.3.514-.55.121-.266.193-.621.23-1.09.027-.34.035-.718.037-1.141A3.5 3.5 0 0 1 4 6.5v-3a.5.5 0 0 1 .5-.5h1V.5A.5.5 0 0 1 6 0" />
                        </svg></span>
                    Beban
                </h5>
            </div>
            <div class="card-body">
                <div class="input-group mb-3">
                    <span class="input-group-text">GT21</span>
                    <input type="text" class="form-control" required>
                    <span class="input-group-text">MW</span>
                </div>
                <div class="input-group mb-3">
                    <span class="input-group-text">GT22</span>
                    <input type="text" class="form-control" required>
                    <span class="input-group-text">MW</span>
                </div>
                <div class="input-group mb-3">
                    <span class="input-group-text">ST28</span>
                    <input type="text" class="form-control" required>
                    <span class="input-group-text">MW</span>
                </div>
                <div class="input-group mb-3">
                    <span class="input-group-text">Total Beban</span>
                    <input type="text" class="form-control" required>
                    <span class="input-group-text">MW</span>
                </div>

            </div>
        </div>

        <!--Card AGC-->
        <div class="card mt-3">
            <div class="card-header">
                <h5 class="card-title text-primary">
                    <span class="me-2"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                            fill="currentColor" class="bi bi-safe2-fill" viewBox="0 0 16 16">
                            <path
                                d="M6.563 8H5.035a3.5 3.5 0 0 1 .662-1.596l1.08 1.08q-.142.24-.214.516m.921-1.223-1.08-1.08A3.5 3.5 0 0 1 8 5.035v1.528q-.277.072-.516.214M9 6.563V5.035a3.5 3.5 0 0 1 1.596.662l-1.08 1.08A2 2 0 0 0 9 6.563m1.223.921 1.08-1.08c.343.458.577 1.003.662 1.596h-1.528a2 2 0 0 0-.214-.516M10.437 9h1.528a3.5 3.5 0 0 1-.662 1.596l-1.08-1.08q.142-.24.214-.516m-.921 1.223 1.08 1.08A3.5 3.5 0 0 1 9 11.965v-1.528q.277-.072.516-.214M8 10.437v1.528a3.5 3.5 0 0 1-1.596-.662l1.08-1.08q.24.142.516.214m-1.223-.921-1.08 1.08A3.5 3.5 0 0 1 5.035 9h1.528q.072.277.214.516M7.5 8.5a1 1 0 1 1 2 0 1 1 0 0 1-2 0" />
                            <path
                                d="M2.5 1A1.5 1.5 0 0 0 1 2.5V3H.5a.5.5 0 0 0 0 1H1v4H.5a.5.5 0 0 0 0 1H1v4H.5a.5.5 0 0 0 0 1H1v.5A1.5 1.5 0 0 0 2.5 16h12a1.5 1.5 0 0 0 1.5-1.5v-12A1.5 1.5 0 0 0 14.5 1zm6 3a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9" />
                        </svg></span>
                    AGC
                </h5>
            </div>

            <div class="card-body">
                <div class="input-group mb-3">
                    <span class="input-group-text" style="width: 10rem;">Vacuum</span>
                    <input type="text" class="form-control" required>
                    <span class="input-group-text">Bara</span>
                </div>
                <div class="input-group mb-3">
                    <span class="input-group-text" style="width: 10rem;">Pemakaian Sendiri</span>
                    <input type="text" class="form-control" required>
                    <span class="input-group-text">MW</span>
                </div>
                <div class="input-group mb-3" id="div-total-produksi">
                    <span class="input-group-text" style="width: 10rem;">Total Produksi</span>
                    <input type="text" class="form-control" value="<%= totProd %>" required>
                    <span class="input-group-text">GWh</span>
                </div>

                <div class="d-flex justify-content-end">
                    <div class="me-3" id="agc21">
                        <input type="checkbox" class="btn-check" id="btn-check-21" autocomplete="off" value="off">
                        <label class="btn btn-outline-primary" for="btn-check-21" id="label-agc-21">AGC GT21 OFF</label>
                    </div>

                    <div id="agc22">
                        <input type="checkbox" class="btn-check" id="btn-check-22" autocomplete="off" value="off">
                        <label class="btn btn-outline-primary" for="btn-check-22" id="label-agc-22">AGC GT22 OFF</label>
                    </div>

                </div>

            </div>
        </div>

        <!--Card Suplai Gas-->
        <div class="card mt-3">

            <div class="card-header">
                <h5 class="card-title text-primary">
                    <span class="me-2"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                            fill="currentColor" class="bi bi-fire" viewBox="0 0 16 16">
                            <path
                                d="M8 16c3.314 0 6-2 6-5.5 0-1.5-.5-4-2.5-6 .25 1.5-1.25 2-1.25 2C11 4 9 .5 6 0c.357 2 .5 4-2 6-1.25 1-2 2.729-2 4.5C2 14 4.686 16 8 16m0-1c-1.657 0-3-1-3-2.75 0-.75.25-2 1.25-3C6.125 10 7 10.5 7 10.5c-.375-1.25.5-3.25 2-3.5-.179 1-.25 2 1 3 .625.5 1 1.364 1 2.25C11 14 9.657 15 8 15" />
                        </svg></span>

                    Supplai Gas
                </h5>
            </div>
            <div class="card-body">
                <div class="input-group mb-3">
                    <span class="input-group-text" style="width: 10rem;">Pressure NG GT21</span>
                    <input type="text" class="form-control" required>
                    <span class="input-group-text">Bar</span>
                </div>
                <div class="input-group mb-3">
                    <span class="input-group-text" style="width: 10rem;">Pressure NG GT22</span>
                    <input type="text" class="form-control" required>
                    <span class="input-group-text">Bar</span>
                </div>
                <div class="input-group mb-3">
                    <span class="input-group-text" style="width: 10rem;">GT21 + Blok 1</span>
                    <input type="text" class="form-control" required>
                    <span class="input-group-text">MMSCFD</span>
                </div>
                <div class="input-group mb-3">
                    <span class="input-group-text" style="width: 10rem;">GT22</span>
                    <input type="text" class="form-control" required>
                    <span class="input-group-text">MMSCFD</span>
                </div>

                <div class="input-group mb-3">
                    <span class="input-group-text" style="width: 10rem;">Pressure</span>
                    <input type="text" class="form-control">
                    <span class="input-group-text">Psi</span>
                </div>
            </div>
        </div>

        <div class="d-grid gap-2 mt-3 mb-5 d-md-flex justify-content-md-end">
            <%# 
            <a href="#" class="btn btn-primary" id="btn-whatsapp">Whatsapp</a>
            <a href="/koordinasi/gas" class="btn btn-secondary" id="btn-kordinasi-gas">Koordinasi Gas</a>
            <button class="btn btn-secondary"  type="button" id="btn-wa">Simulasi Nilai</button>
            %>
            <button class="btn btn-primary"  type="submit" id="btn-waa">Koordinasi PLTGU</button>
            <button class="btn btn-danger d-none"  type="button" id="btn-gas">Koordinasi Gas</button>
        </div>
    </div>
</form>
    <div class="col-12 col-lg-6 col-xl-8">
        <div class="form-floating">
            <textarea class="form-control" placeholder="Leave a comment here" id="laporan-text-area"
                style="height: 600px"></textarea>
            <label for="floatingTextarea2">Laporan</label>
        </div>

    </div>
</div>